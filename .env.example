# ── AI 模型 provider(记忆提纯 + 向量嵌入)──────────────────────────
# 用哪家就填哪家的 key。不填也能用:浏览 + 关键词检索照常;提纯 / 嵌入 / 语义召回会降级。
# 也可在面板「设置」里可视化填写 + 一键测连通。
# 支持:dashscope | openai | deepseek | zhipu | moonshot | siliconflow | custom
LLM_PROVIDER=dashscope
LLM_API_KEY=
# 下面留空则走 provider 预设默认;要覆盖模型 / 地址再填:
LLM_MODEL=
LLM_BASE_URL=
# 嵌入(可与对话不同家;留空则跟随上面)。注意 deepseek / moonshot 不提供嵌入,需另配一家(如 openai / dashscope)。
EMBED_API_KEY=
EMBED_MODEL=
EMBED_BASE_URL=
EMBED_DIM=

# ── 向后兼容:旧字段仍可用(等价于 dashscope)────────────────────────
ALIBABA_KEY=
ALIBABA_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation

# ── 可选 ──────────────────────────────────────────────────────────
# 仅 scripts/probe_models.py 做模型对比时才用:
MINIMAX_KEY=
MINIMAX_ENDPOINT=https://api.minimax.io/v1/text/chatcompletion_v2
# 给记忆提纯 prompt 署名的角色名(如你的品牌 / 昵称);留空则用中性「记忆提纯器」:
PERSONA_NAME=
